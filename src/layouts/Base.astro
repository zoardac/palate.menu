---
const { title = '✦Palate — Where Food Meets Music' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="The social platform where every dish finds its song — and every meal becomes a memory worth sharing." />
  <meta property="og:title" content="✦Palate" />
  <meta property="og:description" content="Where food meets music. Request early access." />
  <meta property="og:url" content="https://palate.menu" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>
